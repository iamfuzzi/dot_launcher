console -"Вы запустили скрипт установки версии Minecraft 1.20.1 с Fabric 0.16.9 под названием Новая сборка и всех нужны файлов"
sleep -3
console -"Вы правда хотите начать?"
get --wait -null -null
console -"Отлично, тогда продолжаем!"
download -1.20.1 -"Новая сборка"
console -"Хотите ли Вы установить Fabric?"
get --yAct -"fabric -0.16.9 -\"Новая сборка\"" -null
libraries -"Новая сборка"
console -"Хотите ли Вы установить ассеты для версии?"
get --yAct -"assets -\"Новая сборка\"" -null